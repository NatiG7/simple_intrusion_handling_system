@startuml
title Deployment Diagram - Intrusion Detection System

node "Admin Workstation" as AdminPC {
    component "Admin Console\n(SSH / Web Browser)" as Console
}

node "IDS Host Server (Linux)" as Server {
    
    component "Network Interface\n(Promiscuous Mode)" as NIC
    
    rectangle "Python Runtime Environment" {
        artifact "IDS Application\n(main.py)" as App
        artifact "Scapy Library" as Scapy
        artifact "ML Model\n(baseline_model.pkl)" as Model
    }
    
    database "Local Storage\n(SQLite / Logs)" as DB
}

cloud "Internet / Intranet" as Network

' Connections
Network .right.> NIC : Raw Traffic
NIC --> Scapy : Capture Packet
Scapy -down-> App : Process
App -right-> Model : Predict
App -down-> DB : Read/Write Logs

Console -left-> App : Management/Alerts (TCP/IP)
@enduml