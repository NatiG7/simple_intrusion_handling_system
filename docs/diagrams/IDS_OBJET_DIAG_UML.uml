@startuml
title Object Diagram - Snapshot during SYN Flood Attack (With DB Detail)

' Style tweaking to make the DB section distinct
skinparam object {
    BackgroundColor<<BSON>> Wheat
    BorderColor<<BSON>> Tomato
}

object "main_app : SystemController" as Controller {
    interface = "eth0"
    is_running = True
}

object "db_handler : DatabaseManager" as DB {
    packet = {PktA}
}

' --- NEW: Packet A (Standard) ---
object "packetA : BSON_Document" as PktA <<BSON>> {
    _id = "60d5ec49..."
    timestamp = "10:30:00Z"
    -- Flow Stats --
    {
    "packet_size" : 4,
    "flow_duraton" : 123,
    "packet_rate": 12,
    "byte_rate": 2,
    "latest_window_size": 1003
    "syn_count": 1,
    "ack_count": 3,
    "fin_count": 0,
    "rst_count": 0,
    "avg_sequence_num": 3252351,
    "avg_window_size": 1004,
    "avg_ip_header_size": 18,
    "avg_tcp_header_size": 2,
    "unique_src_ips":1,
    "unique_dst_ips":1,
    "unique_src_ports":3,
    "unique_dst_ports":1,
    "ip_checksum_errors": {"ip_checksum_errors"},
    "tcp_checksum_errors": {"tcp_checksum_errors"},
    "reserved_bit_set_count": 4}


}

object "sniffer : PacketCapture" as Sniffer {
    packet_queue = [Size: 45]
    stop_event = False
}

object "packet_105 : Packet" as Pkt {
    src_ip = "192.168.1.50"
    dst_ip = "10.0.0.1"
    flags = "S" (SYN)
    size = 64
}

object "analyser : TrafficAnalysis" as Analyser {
    flow_stats = {Key: (192.168.1.50 -> 10.0.0.1)}
}

object "current_flow : FlowStats" as Flow {
    packet_count = 500
    syn_count = 498
    ack_count = 0
    duration = 2.5s
}

object "detector : ThreatDetector" as Detector {
    signature_rules = Loaded
}

object "ml_model : FlowMLModel" as AI {
    is_trained = True
    contamination = 0.01
}

' Links
Controller -- DB
Controller -- Sniffer
Controller -- Analyser
Controller -- Detector

' Composition links showing these packets are INSIDE the DB
DB *-- PktA : stored_item_1

Detector -- DB : saves_alert
Sniffer ..> Pkt : just_captured
Analyser ..> Pkt : processing
Analyser -- Flow : updates
Detector -- AI : queries

note right of Flow
  Suspicious State:
  High SYN count
  Low ACK count
end note

@enduml